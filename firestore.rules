rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() && 
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    function isNotBanned() {
      return isAuthenticated() && 
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.status == 'active';
    }

    function changed() {
      return request.resource.data.diff(resource.data).affectedKeys();
    }

    function isBlockedWith(otherUserId) {
      return isAuthenticated() && (
        exists(/databases/$(database)/documents/users/$(request.auth.uid)/blockedUsers/$(otherUserId)) ||
        exists(/databases/$(database)/documents/users/$(otherUserId)/blockedUsers/$(request.auth.uid))
      );
    }

    match /users/{userId} {
      match /private/fcm {
        allow read: if isOwner(userId);
        allow write: if isOwner(userId) && isNotBanned();
      }

      allow read: if isAuthenticated();

      allow create: if isAuthenticated() && isOwner(userId) &&
        request.resource.data.status in ['active', 'banned'] &&
        request.resource.data.role == 'user';

      allow update: if isAuthenticated() && (
        isAdmin() ||
        (isOwner(userId) && isNotBanned() && !changed().hasAny(['role', 'status']))
      );

      allow delete: if isAuthenticated() && isOwner(userId) && isNotBanned();

      match /friends/{friendId} {
        allow read: if isAuthenticated() && (isOwner(userId) || isOwner(friendId));

        allow create: if isNotBanned() &&
          (isOwner(userId) || isOwner(friendId)) &&
          request.resource.data.keys().hasOnly(['friendId', 'createdAt']) &&
          request.resource.data.friendId == friendId;

        allow delete: if isAuthenticated() && (isOwner(userId) || isOwner(friendId));
      }

      match /blockedUsers/{blockedUid} {
        allow read: if isOwner(userId) || (isAuthenticated() && blockedUid == request.auth.uid);
        allow create, update, delete: if isOwner(userId) && isNotBanned();
      }

      match /feeds/{postId} {
        allow read: if isOwner(userId);
        allow write: if false;
      }
    }

    match /friendRequests/{requestId} {
      allow read: if isAuthenticated() &&
        (resource.data.senderId == request.auth.uid ||
         resource.data.receiverId == request.auth.uid);

      allow create: if isNotBanned() &&
        request.resource.data.senderId == request.auth.uid &&
        request.resource.data.senderId != request.resource.data.receiverId &&
        !isBlockedWith(request.resource.data.receiverId) &&
        request.resource.data.status == 'pending';

      allow update: if isNotBanned() &&
        (resource.data.senderId == request.auth.uid ||
         resource.data.receiverId == request.auth.uid) &&
        request.resource.data.senderId == resource.data.senderId &&
        request.resource.data.receiverId == resource.data.receiverId &&
        (request.resource.data.status != 'accepted' ||
         resource.data.receiverId == request.auth.uid);

      allow delete: if isAuthenticated() &&
        (resource.data.senderId == request.auth.uid ||
         resource.data.receiverId == request.auth.uid);
    }

    match /posts/{postId} {
      allow read: if isAuthenticated() && !isBlockedWith(resource.data.authorId) && (
        resource.data.visibility == 'public' ||
        resource.data.authorId == request.auth.uid ||
        (resource.data.visibility == 'friends' &&
         exists(/databases/$(database)/documents/users/$(resource.data.authorId)/friends/$(request.auth.uid))) ||
        isAdmin()
      );

      allow create: if isNotBanned() &&
        request.resource.data.authorId == request.auth.uid &&
        request.resource.data.visibility in ['public', 'friends', 'private'] &&
        request.resource.data.status == 'active' &&
        request.resource.data.commentCount == 0;

      allow update: if isAuthenticated() && (
        (resource.data.authorId == request.auth.uid && isNotBanned() &&
         (changed().hasOnly(['content', 'media', 'visibility', 'isEdited', 'editedAt']) ||
          changed().hasOnly(['status', 'deletedAt', 'deletedBy']))) ||
        (isNotBanned() && !isBlockedWith(resource.data.authorId) && changed().hasOnly(['commentCount', 'reactions']))
      );

      allow delete: if isAuthenticated() && (
        (resource.data.authorId == request.auth.uid && isNotBanned()) ||
        isAdmin()
      );

      match /reactions/{reactorId} {
        // Cho phép đọc danh sách reaction. Client tự chia quyền hiển thị.
        allow read: if isAuthenticated() && !isBlockedWith(get(/databases/$(database)/documents/posts/$(postId)).data.authorId);
        allow write: if isNotBanned() && reactorId == request.auth.uid && !isBlockedWith(get(/databases/$(database)/documents/posts/$(postId)).data.authorId);
      }
    }

    match /comments/{commentId} {
      // Cho phép đọc danh sách comment để Client tự chia quyền hiển thị.
      allow read: if isAuthenticated() && !isBlockedWith(get(/databases/$(database)/documents/posts/$(resource.data.postId)).data.authorId);

      allow create: if isNotBanned() &&
        request.resource.data.authorId == request.auth.uid &&
        !isBlockedWith(get(/databases/$(database)/documents/posts/$(request.resource.data.postId)).data.authorId) &&
        (request.resource.data.parentId == null || !isBlockedWith(get(/databases/$(database)/documents/comments/$(request.resource.data.parentId)).data.authorId)) &&
        request.resource.data.status == 'active' &&
        request.resource.data.replyCount == 0;

      allow update: if isAuthenticated() && (
        (resource.data.authorId == request.auth.uid && isNotBanned() && 
         changed().hasOnly(['content', 'image', 'isEdited', 'editedAt'])) ||
        (resource.data.authorId == request.auth.uid && isNotBanned() && 
         changed().hasOnly(['content', 'isEdited', 'editedAt'])) ||
        (resource.data.authorId == request.auth.uid && isNotBanned() &&
         changed().hasOnly(['status', 'deletedAt', 'deletedBy'])) ||
        (isNotBanned() && !isBlockedWith(resource.data.authorId) && changed().hasOnly(['replyCount', 'reactions']))
      );

      allow delete: if isAuthenticated() && (
        (resource.data.authorId == request.auth.uid && isNotBanned()) ||
        (isNotBanned() &&
         get(/databases/$(database)/documents/posts/$(resource.data.postId)).data.authorId == request.auth.uid) ||
        (resource.data.parentId != null &&
         get(/databases/$(database)/documents/comments/$(resource.data.parentId)).data.authorId == request.auth.uid) ||
        isAdmin()
      );

      match /reactions/{reactorId} {
        // Cho phép đọc danh sách nếu có quyền đọc bình luận.
        allow read: if isAuthenticated() && !isBlockedWith(get(/databases/$(database)/documents/comments/$(commentId)).data.authorId);
        allow write: if isNotBanned() && reactorId == request.auth.uid && !isBlockedWith(get(/databases/$(database)/documents/comments/$(commentId)).data.authorId);
      }
    }

    match /notifications/{notificationId} {
      allow read: if isAuthenticated() && (
        resource.data.receiverId == request.auth.uid ||
        resource.data.actorId == request.auth.uid
      );

      allow create: if false;

      allow update: if isAuthenticated() &&
        resource.data.receiverId == request.auth.uid &&
        changed().hasOnly(['isRead']);

      allow delete: if isAuthenticated() && (
        resource.data.receiverId == request.auth.uid ||
        resource.data.actorId == request.auth.uid ||
        isAdmin()
      );
    }

    match /config/{document} {
      allow read: if isAuthenticated();
      allow write: if false;
    }

    match /reports/{reportId} {
      allow create: if isNotBanned() &&
        request.resource.data.reporterId == request.auth.uid &&
        request.resource.data.reporterId != request.resource.data.targetOwnerId &&
        request.resource.data.status == 'pending' &&
        request.resource.data.targetType in ['post', 'comment', 'user'];

      allow read: if isAuthenticated() && (
        resource.data.reporterId == request.auth.uid ||
        resource.data.targetOwnerId == request.auth.uid ||
        isAdmin()
      );

      allow update: if isAuthenticated() && isAdmin();

      allow delete: if isAuthenticated() && (
        resource.data.reporterId == request.auth.uid ||
        resource.data.targetOwnerId == request.auth.uid ||
        isAdmin()
      );
    }
  }
}


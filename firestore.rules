rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ══════════════════════════════════════════
    // USERS - owner write, friendIds/blockedUserIds cho interactions
    // ══════════════════════════════════════════
    match /users/{userId} {
      allow read: if request.auth != null;
      allow create, delete: if request.auth != null && request.auth.uid == userId;
      allow update: if request.auth != null && (
        request.auth.uid == userId || 
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['friendIds', 'blockedUserIds'])
      );
    }
    
    // ══════════════════════════════════════════
    // FRIEND REQUESTS - sender/receiver access
    // ══════════════════════════════════════════
    match /friendRequests/{requestId} {
      allow read: if request.auth != null && 
        (resource.data.senderId == request.auth.uid || 
         resource.data.receiverId == request.auth.uid);
      allow create: if request.auth != null && 
        request.resource.data.senderId == request.auth.uid;
      allow update: if request.auth != null && 
        (resource.data.senderId == request.auth.uid || 
         resource.data.receiverId == request.auth.uid);
      allow delete: if request.auth != null && 
        resource.data.senderId == request.auth.uid;
    }
    
    // ══════════════════════════════════════════
    // POSTS - privacy: owner, friends, admin
    // ══════════════════════════════════════════
    match /posts/{postId} {
      allow read: if request.auth != null && (
        resource.data.visibility == 'public' ||
        resource.data.userId == request.auth.uid || 
        request.auth.uid in get(/databases/$(database)/documents/users/$(resource.data.userId)).data.friendIds ||
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin'
      );
      allow create: if request.auth != null && 
        request.resource.data.userId == request.auth.uid &&
        request.resource.data.visibility in ['public', 'friends', 'private'];
      // Cho phép update likes/commentCount từ bất kỳ ai
      allow update: if request.auth != null && (
        resource.data.userId == request.auth.uid || 
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['commentCount', 'likes'])
      );
      allow delete: if request.auth != null && (
        resource.data.userId == request.auth.uid ||
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin'
      );
    }
    
    // ══════════════════════════════════════════
    // COMMENTS - privacy theo post owner's friends + cascade delete
    // ══════════════════════════════════════════
    match /comments/{commentId} {
      // Read: owner, post owner, post owner's friends, parent comment owner, admin
      allow read: if request.auth != null && (
        resource.data.userId == request.auth.uid || 
        get(/databases/$(database)/documents/posts/$(resource.data.postId)).data.userId == request.auth.uid ||
        request.auth.uid in get(/databases/$(database)/documents/users/$(get(/databases/$(database)/documents/posts/$(resource.data.postId)).data.userId)).data.friendIds ||
        (resource.data.parentId != null && get(/databases/$(database)/documents/comments/$(resource.data.parentId)).data.userId == request.auth.uid) ||
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin'
      );
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      // Cho phép update likes/replyCount từ bất kỳ ai
      allow update: if request.auth != null && (
        resource.data.userId == request.auth.uid || 
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['replyCount', 'likes'])
      );
      // Delete: owner, post owner, parent comment owner, admin
      allow delete: if request.auth != null && (
        resource.data.userId == request.auth.uid || 
        get(/databases/$(database)/documents/posts/$(resource.data.postId)).data.userId == request.auth.uid ||
        (resource.data.parentId != null && get(/databases/$(database)/documents/comments/$(resource.data.parentId)).data.userId == request.auth.uid) ||
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin'
      );
    }
    
    // ══════════════════════════════════════════
    // CONVERSATIONS - participants only
    // ══════════════════════════════════════════
    match /conversations/{conversationId} {
      allow read, create, delete: if request.auth != null && 
        request.auth.uid in (resource != null ? resource.data.participantIds : request.resource.data.participantIds);
      allow update: if request.auth != null && 
        (request.auth.uid in resource.data.participantIds);
    }
    
    // ══════════════════════════════════════════
    // MESSAGES - participants access, senderId = system cho system messages
    // ══════════════════════════════════════════
    match /messages/{messageId} {
      allow read: if request.auth != null && 
        request.auth.uid in get(/databases/$(database)/documents/conversations/$(resource.data.conversationId)).data.participantIds;
      allow create: if request.auth != null && 
        (request.resource.data.senderId == request.auth.uid || request.resource.data.senderId == 'system') &&
        request.auth.uid in get(/databases/$(database)/documents/conversations/$(request.resource.data.conversationId)).data.participantIds;
      // Cho phép update readBy/deliveredAt/deletedBy từ participants
      allow update: if request.auth != null && (
        resource.data.senderId == request.auth.uid || 
        (request.auth.uid in get(/databases/$(database)/documents/conversations/$(resource.data.conversationId)).data.participantIds && 
         request.resource.data.diff(resource.data).affectedKeys().hasOnly(['readBy', 'deliveredAt', 'deliveredTo', 'deletedBy']))
      );
      allow delete: if request.auth != null && resource.data.senderId == request.auth.uid;
    }

    // ══════════════════════════════════════════
    // NOTIFICATIONS - receiver access, delete cho cleanup cascade
    // ══════════════════════════════════════════
    match /notifications/{notificationId} {
      allow read: if request.auth != null && resource.data.receiverId == request.auth.uid;
      allow create: if request.auth != null;
      allow update: if request.auth != null && resource.data.receiverId == request.auth.uid && 
                    request.resource.data.diff(resource.data).affectedKeys().hasOnly(['isRead']);
      // Delete: receiver, sender, post owner (nếu post còn tồn tại), admin
      allow delete: if request.auth != null && (
        resource.data.receiverId == request.auth.uid ||
        resource.data.senderId == request.auth.uid ||
        (resource.data.data.postId != null && 
         exists(/databases/$(database)/documents/posts/$(resource.data.data.postId)) &&
         get(/databases/$(database)/documents/posts/$(resource.data.data.postId)).data.userId == request.auth.uid) ||
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin'
      );
    }

    // ══════════════════════════════════════════
    // REPORTS - reporter/admin read, orphaned status cho cascade
    // ══════════════════════════════════════════
    match /reports/{reportId} {
      // Không cho phép tự báo cáo chính mình
      allow create: if request.auth != null && 
        request.resource.data.reporterId == request.auth.uid &&
        request.resource.data.reporterId != request.resource.data.targetOwnerId;
      
      allow read: if request.auth != null && (
        resource.data.reporterId == request.auth.uid ||
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin'
      );
      
      // Admin: full fields | Target owner: orphaned only | Post owner: orphaned comment reports
      allow update: if request.auth != null && (
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' &&
         request.resource.data.diff(resource.data).affectedKeys()
           .hasOnly(['status', 'resolvedAt', 'resolvedBy', 'resolution'])) ||
        (resource.data.targetOwnerId == request.auth.uid &&
         request.resource.data.status == 'orphaned' &&
         request.resource.data.diff(resource.data).affectedKeys()
           .hasOnly(['status', 'resolution'])) ||
        (resource.data.targetType == 'comment' &&
         exists(/databases/$(database)/documents/comments/$(resource.data.targetId)) &&
         exists(/databases/$(database)/documents/posts/$(get(/databases/$(database)/documents/comments/$(resource.data.targetId)).data.postId)) &&
         get(/databases/$(database)/documents/posts/$(get(/databases/$(database)/documents/comments/$(resource.data.targetId)).data.postId)).data.userId == request.auth.uid &&
         request.resource.data.status == 'orphaned' &&
         request.resource.data.diff(resource.data).affectedKeys()
           .hasOnly(['status', 'resolution']))
      );
      
      allow delete: if request.auth != null && (
        resource.data.reporterId == request.auth.uid ||
        resource.data.targetOwnerId == request.auth.uid ||
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin'
      );
    }
  }
}

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    // Admin và banned dùng Custom Claims — không cần Firestore read
    function isAdmin() {
      return isAuthenticated() && request.auth.token.admin == true;
    }

    function isNotBanned() {
      return isAuthenticated() && request.auth.token.banned != true;
    }

    // Danh sách các trường dữ liệu thay đổi.
    function changed() {
      return request.resource.data.diff(resource.data).affectedKeys();
    }

    // QUẢN LÝ NGƯỜI DÙNG
    match /users/{userId} {
      // Dữ liệu nhạy cảm — chỉ owner
      match /private/security {
        allow read, write: if isOwner(userId) && isNotBanned();
      }
      // FCM tokens — CF-only write
      match /private/fcm {
        allow read: if isOwner(userId);
        allow write: if false;
      }
      allow read: if isAuthenticated();

      allow create: if isAuthenticated() && isOwner(userId) &&
        request.resource.data.status in ['online', 'offline'] &&
        // Role chỉ được set qua Custom Claims — chặn ghi trực tiếp
        !('role' in request.resource.data);

      allow update: if isAuthenticated() && (
        // Quyền admin toàn phần.
        isAdmin() ||
        // Chủ sở hữu không được tự đổi role hay friendIds (CF xử lý).
        (isOwner(userId) && isNotBanned() && !changed().hasAny(['role', 'friendIds']))
      );

      allow delete: if isAuthenticated() && isOwner(userId) && isNotBanned();
    }

    // LỜI MỜI KẾT BẠN
    match /friendRequests/{requestId} {
      allow read: if isAuthenticated() &&
        (resource.data.senderId == request.auth.uid ||
         resource.data.receiverId == request.auth.uid);

      // Chặn tự mời kết bạn, mặc định chờ duyệt.
      allow create: if isNotBanned() &&
        request.resource.data.senderId == request.auth.uid &&
        request.resource.data.senderId != request.resource.data.receiverId &&
        request.resource.data.status == 'pending';

      allow update: if isNotBanned() &&
        (resource.data.senderId == request.auth.uid ||
         resource.data.receiverId == request.auth.uid) &&
        // Không cho phép đổi thông tin người gửi/nhận.
        request.resource.data.senderId == resource.data.senderId &&
        request.resource.data.receiverId == resource.data.receiverId &&
        // Chỉ người nhận mới có quyền chấp nhận.
        (request.resource.data.status != 'accepted' ||
         resource.data.receiverId == request.auth.uid);

      allow delete: if isAuthenticated() &&
        (resource.data.senderId == request.auth.uid ||
         resource.data.receiverId == request.auth.uid);
    }

    // BÀI VIẾT
    match /posts/{postId} {
      allow read: if isAuthenticated() && (
        resource.data.visibility == 'public' ||
        resource.data.userId == request.auth.uid ||
        (resource.data.visibility == 'friends' &&
         request.auth.uid in get(/databases/$(database)/documents/users/$(resource.data.userId)).data.friendIds) ||
        isAdmin()
      );

      // Số lượng bình luận khởi tạo bằng 0.
      allow create: if isNotBanned() &&
        request.resource.data.userId == request.auth.uid &&
        request.resource.data.visibility in ['public', 'friends', 'private'] &&
        request.resource.data.commentCount == 0;

      allow update: if isAuthenticated() && (
        // Chủ bài viết
        (resource.data.userId == request.auth.uid && isNotBanned()) ||
        // Chỉ cho phép cập nhật tương tác.
        (isNotBanned() && changed().hasOnly(['commentCount', 'reactions']))
      );

      allow delete: if isAuthenticated() && (
        (resource.data.userId == request.auth.uid && isNotBanned()) ||
        isAdmin()
      );
    }

    // BÌNH LUẬN
    match /comments/{commentId} {
      // Quyền xem phụ thuộc vào bài viết.
      allow read: if isAuthenticated();

      // Số lượng phản hồi khởi tạo bằng 0.
      allow create: if isNotBanned() &&
        request.resource.data.userId == request.auth.uid &&
        request.resource.data.postId is string &&
        request.resource.data.replyCount == 0;

      allow update: if isAuthenticated() && (
        // Chủ comment
        (resource.data.userId == request.auth.uid && isNotBanned()) ||
        // Chỉ cho phép cập nhật cảm xúc/phản hồi.
        (isNotBanned() && changed().hasOnly(['replyCount', 'reactions']))
      );

      allow delete: if isAuthenticated() && (
        (resource.data.userId == request.auth.uid && isNotBanned()) ||
        // Chủ bài viết được quyền xóa mọi bình luận.
        (isNotBanned() &&
         get(/databases/$(database)/documents/posts/$(resource.data.postId)).data.userId == request.auth.uid) ||
        // Chủ bình luận được xóa các phản hồi.
        (resource.data.parentId != null &&
         get(/databases/$(database)/documents/comments/$(resource.data.parentId)).data.userId == request.auth.uid) ||
        isAdmin()
      );
    }

    // CUỘC TRÒ CHUYỆN
    match /conversations/{conversationId} {
      allow read: if isAuthenticated() &&
        request.auth.uid in resource.data.participantIds;

      // Yêu cầu nhóm tối thiểu 2 người.
      allow create: if isNotBanned() &&
        request.auth.uid in request.resource.data.participantIds &&
        request.resource.data.participantIds.size() >= 2;

      allow update: if isAuthenticated() &&
        request.auth.uid in resource.data.participantIds && (
          // Quyền quản trị viên nhóm.
          resource.data.creatorId == request.auth.uid ||
          ('adminIds' in resource.data && request.auth.uid in resource.data.adminIds) ||
          // Thành viên không có quyền đổi thông tin nhóm.
          !changed().hasAny(['adminIds', 'creatorId', 'groupName', 'groupAvatar'])
        );

      allow delete: if isAuthenticated() &&
        request.auth.uid in resource.data.participantIds;
    }

    // TIN NHẮN
    match /messages/{messageId} {
      allow read: if isAuthenticated() &&
        request.auth.uid in
          get(/databases/$(database)/documents/conversations/$(resource.data.conversationId)).data.participantIds;

      // Chỉ hệ thống mới được gửi tin nhắn tự động.
      allow create: if isNotBanned() &&
        request.auth.uid in
          get(/databases/$(database)/documents/conversations/$(request.resource.data.conversationId)).data.participantIds &&
        (request.resource.data.senderId == request.auth.uid ||
         (request.resource.data.senderId == 'system' && request.resource.data.type == 'system'));

      allow update: if isAuthenticated() && (
        // Người gửi được thu hồi hoặc sửa tin nhắn.
        (resource.data.senderId == request.auth.uid && isNotBanned() &&
         changed().hasOnly(['content', 'isRecalled', 'recalledAt', 'isEdited', 'editedAt'])) ||
        // Thành viên thực hiện tương tác tin nhắn.
        (request.auth.uid in
          get(/databases/$(database)/documents/conversations/$(resource.data.conversationId)).data.participantIds &&
         changed().hasOnly(['readBy', 'deliveredAt', 'deliveredTo', 'deletedBy', 'reactions']))
      );

      allow delete: if isAuthenticated() &&
        resource.data.senderId == request.auth.uid && isNotBanned();
    }

    // THÔNG BÁO
    match /notifications/{notificationId} {
      allow read: if isAuthenticated() && (
        resource.data.receiverId == request.auth.uid ||
        resource.data.senderId == request.auth.uid
      );

      // Notifications chỉ được tạo bửi Cloud Functions (server-side)
      allow create: if false;

      allow update: if isAuthenticated() &&
        resource.data.receiverId == request.auth.uid &&
        changed().hasOnly(['isRead']);

      allow delete: if isAuthenticated() && (
        resource.data.receiverId == request.auth.uid ||
        resource.data.senderId == request.auth.uid ||
        isAdmin()
      );
    }

    // CẤU HÌNH HỆ THỐNG (CF-only write)
    match /config/{document} {
      allow read: if isAuthenticated();
      allow write: if false;
    }

    // BÁO CÁO VI PHẠM
    match /reports/{reportId} {
      // Chặn tự báo cáo, mặc định chờ xử lý.
      allow create: if isNotBanned() &&
        request.resource.data.reporterId == request.auth.uid &&
        request.resource.data.reporterId != request.resource.data.targetOwnerId &&
        request.resource.data.status == 'pending' &&
        request.resource.data.targetType in ['post', 'comment', 'user'];

      // Truy cập để xử lý báo cáo khi nội dung bị xóa.
      allow read: if isAuthenticated() && (
        resource.data.reporterId == request.auth.uid ||
        resource.data.targetOwnerId == request.auth.uid ||
        isAdmin()
      );

      allow update: if isAuthenticated() && (
        // Chỉ Admin mới được cập nhật (resolve/reject) — CF xử lý orphaned tự động
        isAdmin()
      );

      allow delete: if isAuthenticated() && (
        resource.data.reporterId == request.auth.uid ||
        resource.data.targetOwnerId == request.auth.uid ||
        isAdmin()
      );
    }
  }
}

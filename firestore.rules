rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isAdmin() {
      return isAuthenticated() && getUserData().role == 'admin';
    }

    function isNotBanned() {
      return isAuthenticated() && getUserData().status != 'banned';
    }

    // Danh sách field thay đổi giữa dữ liệu cũ và mới
    function changed() {
      return request.resource.data.diff(resource.data).affectedKeys();
    }

    // ======================== USERS ========================
    match /users/{userId} {
      allow read: if isAuthenticated();

      allow create: if isAuthenticated() && isOwner(userId) &&
        request.resource.data.status in ['online', 'offline'] &&
        (!('role' in request.resource.data) || request.resource.data.role == 'user');

      allow update: if isAuthenticated() && (
        // Admin toàn quyền (ban/unban/role)
        isAdmin() ||
        // Chủ tài khoản — chặn tự nâng role
        (isOwner(userId) && isNotBanned() && !changed().hasAny(['role'])) ||
        // Kết bạn/hủy kết bạn — chỉ add/remove chính mình trong friendIds
        (isNotBanned() &&
         changed().hasOnly(['friendIds']) &&
         (request.resource.data.friendIds.hasAll([request.auth.uid]) ||
          ('friendIds' in resource.data && resource.data.friendIds.hasAll([request.auth.uid]))))
      );

      allow delete: if isAuthenticated() && isOwner(userId) && isNotBanned();
    }

    // ======================== FRIEND REQUESTS ========================
    match /friendRequests/{requestId} {
      allow read: if isAuthenticated() &&
        (resource.data.senderId == request.auth.uid ||
         resource.data.receiverId == request.auth.uid);

      // Chặn gửi cho chính mình, bắt buộc status = pending khi tạo
      allow create: if isNotBanned() &&
        request.resource.data.senderId == request.auth.uid &&
        request.resource.data.senderId != request.resource.data.receiverId &&
        request.resource.data.status == 'pending';

      allow update: if isNotBanned() &&
        (resource.data.senderId == request.auth.uid ||
         resource.data.receiverId == request.auth.uid) &&
        // Không được đổi senderId/receiverId
        request.resource.data.senderId == resource.data.senderId &&
        request.resource.data.receiverId == resource.data.receiverId &&
        // Chỉ receiver được accept
        (request.resource.data.status != 'accepted' ||
         resource.data.receiverId == request.auth.uid);

      allow delete: if isAuthenticated() &&
        (resource.data.senderId == request.auth.uid ||
         resource.data.receiverId == request.auth.uid);
    }

    // ======================== POSTS ========================
    match /posts/{postId} {
      allow read: if isAuthenticated() && (
        resource.data.visibility == 'public' ||
        resource.data.userId == request.auth.uid ||
        (resource.data.visibility == 'friends' &&
         request.auth.uid in get(/databases/$(database)/documents/users/$(resource.data.userId)).data.friendIds) ||
        isAdmin()
      );

      // commentCount phải khởi tạo = 0
      allow create: if isNotBanned() &&
        request.resource.data.userId == request.auth.uid &&
        request.resource.data.visibility in ['public', 'friends', 'private'] &&
        request.resource.data.commentCount == 0;

      allow update: if isAuthenticated() && (
        // Chủ bài viết
        (resource.data.userId == request.auth.uid && isNotBanned()) ||
        // Tương tác: reaction hoặc commentCount
        (isNotBanned() && changed().hasOnly(['commentCount', 'reactions']))
      );

      allow delete: if isAuthenticated() && (
        (resource.data.userId == request.auth.uid && isNotBanned()) ||
        isAdmin()
      );
    }

    // ======================== COMMENTS ========================
    match /comments/{commentId} {
      // Post visibility đã kiểm soát quyền xem ở tầng post
      allow read: if isAuthenticated();

      // replyCount phải khởi tạo = 0
      allow create: if isNotBanned() &&
        request.resource.data.userId == request.auth.uid &&
        request.resource.data.postId is string &&
        request.resource.data.replyCount == 0;

      allow update: if isAuthenticated() && (
        // Chủ comment
        (resource.data.userId == request.auth.uid && isNotBanned()) ||
        // Tương tác: like hoặc replyCount
        (isNotBanned() && changed().hasOnly(['replyCount', 'likes']))
      );

      allow delete: if isAuthenticated() && (
        (resource.data.userId == request.auth.uid && isNotBanned()) ||
        // Chủ bài viết có quyền xóa comment trên bài
        (isNotBanned() &&
         get(/databases/$(database)/documents/posts/$(resource.data.postId)).data.userId == request.auth.uid) ||
        // Chủ comment cha có quyền xóa reply
        (resource.data.parentId != null &&
         get(/databases/$(database)/documents/comments/$(resource.data.parentId)).data.userId == request.auth.uid) ||
        isAdmin()
      );
    }

    // ======================== CONVERSATIONS ========================
    match /conversations/{conversationId} {
      allow read: if isAuthenticated() &&
        request.auth.uid in resource.data.participantIds;

      // Tối thiểu 2 thành viên
      allow create: if isNotBanned() &&
        request.auth.uid in request.resource.data.participantIds &&
        request.resource.data.participantIds.size() >= 2;

      allow update: if isAuthenticated() &&
        request.auth.uid in resource.data.participantIds && (
          // Creator hoặc admin nhóm: toàn quyền
          resource.data.creatorId == request.auth.uid ||
          ('adminIds' in resource.data && request.auth.uid in resource.data.adminIds) ||
          // Thành viên thường: không sửa adminIds, creatorId, groupName, groupAvatar
          !changed().hasAny(['adminIds', 'creatorId', 'groupName', 'groupAvatar'])
        );

      allow delete: if isAuthenticated() &&
        request.auth.uid in resource.data.participantIds;
    }

    // ======================== MESSAGES ========================
    match /messages/{messageId} {
      allow read: if isAuthenticated() &&
        request.auth.uid in
          get(/databases/$(database)/documents/conversations/$(resource.data.conversationId)).data.participantIds;

      // senderId = 'system' chỉ hợp lệ khi type = 'system'
      allow create: if isNotBanned() &&
        request.auth.uid in
          get(/databases/$(database)/documents/conversations/$(request.resource.data.conversationId)).data.participantIds &&
        (request.resource.data.senderId == request.auth.uid ||
         (request.resource.data.senderId == 'system' && request.resource.data.type == 'system'));

      allow update: if isAuthenticated() && (
        // Chủ tin nhắn: thu hồi / chỉnh sửa
        (resource.data.senderId == request.auth.uid && isNotBanned() &&
         changed().hasOnly(['content', 'isRecalled', 'recalledAt', 'isEdited', 'editedAt'])) ||
        // Thành viên hội thoại: đánh dấu đã đọc / xóa phía mình / reaction
        (request.auth.uid in
          get(/databases/$(database)/documents/conversations/$(resource.data.conversationId)).data.participantIds &&
         changed().hasOnly(['readBy', 'deliveredAt', 'deliveredTo', 'deletedBy', 'reactions']))
      );

      allow delete: if isAuthenticated() &&
        resource.data.senderId == request.auth.uid && isNotBanned();
    }

    // ======================== NOTIFICATIONS ========================
    match /notifications/{notificationId} {
      allow read: if isAuthenticated() &&
        resource.data.receiverId == request.auth.uid;

      // isRead phải khởi tạo = false
      allow create: if isNotBanned() &&
        request.resource.data.senderId == request.auth.uid &&
        request.resource.data.isRead == false;

      allow update: if isAuthenticated() &&
        resource.data.receiverId == request.auth.uid &&
        changed().hasOnly(['isRead']);

      allow delete: if isAuthenticated() && (
        resource.data.receiverId == request.auth.uid ||
        resource.data.senderId == request.auth.uid ||
        isAdmin()
      );
    }

    // ======================== REPORTS ========================
    match /reports/{reportId} {
      // Chặn tự báo cáo, bắt buộc status = pending
      allow create: if isNotBanned() &&
        request.resource.data.reporterId == request.auth.uid &&
        request.resource.data.reporterId != request.resource.data.targetOwnerId &&
        request.resource.data.status == 'pending' &&
        request.resource.data.targetType in ['post', 'comment', 'user'];

      // targetOwnerId cần đọc để archive reports khi xóa nội dung
      allow read: if isAuthenticated() && (
        resource.data.reporterId == request.auth.uid ||
        resource.data.targetOwnerId == request.auth.uid ||
        isAdmin()
      );

      allow update: if isAuthenticated() && (
        isAdmin() ||
        // Chủ nội dung đánh dấu orphaned khi xóa nội dung
        (resource.data.targetOwnerId == request.auth.uid &&
         request.resource.data.status == 'orphaned' &&
         changed().hasOnly(['status', 'resolution'])) ||
        // Chủ bài viết đánh dấu orphaned cho report về comment trên bài
        (resource.data.targetType == 'comment' &&
         exists(/databases/$(database)/documents/comments/$(resource.data.targetId)) &&
         exists(/databases/$(database)/documents/posts/$(
           get(/databases/$(database)/documents/comments/$(resource.data.targetId)).data.postId)) &&
         get(/databases/$(database)/documents/posts/$(
           get(/databases/$(database)/documents/comments/$(resource.data.targetId)).data.postId)).data.userId == request.auth.uid &&
         request.resource.data.status == 'orphaned' &&
         changed().hasOnly(['status', 'resolution']))
      );

      allow delete: if isAuthenticated() && (
        resource.data.reporterId == request.auth.uid ||
        resource.data.targetOwnerId == request.auth.uid ||
        isAdmin()
      );
    }
  }
}

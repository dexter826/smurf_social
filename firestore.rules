rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    function isEmailVerified() {
      return request.auth.token.email_verified == true;
    }

    function isAdmin() {
      return isAuthenticated() && 
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.status == 'active' &&
        isEmailVerified();
    }

    function isNotBanned() {
      return isAuthenticated() && 
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.status == 'active';
    }

    function canWrite() {
      return isNotBanned() && isEmailVerified();
    }

    function changed() {
      return request.resource.data.diff(resource.data).affectedKeys();
    }

    function isBlockedWith(otherUserId) {
      return isAuthenticated() && (
        exists(/databases/$(database)/documents/users/$(request.auth.uid)/blockedUsers/$(otherUserId)) ||
        exists(/databases/$(database)/documents/users/$(otherUserId)/blockedUsers/$(request.auth.uid))
      );
    }

    function isFriend(userId) {
      return isAuthenticated() && exists(/databases/$(database)/documents/users/$(userId)/friends/$(request.auth.uid));
    }

    // Quản lý người dùng
    match /users/{userId} {
      match /private/fcm {
        allow read, write: if isOwner(userId);
      }

      match /private/settings {
        allow read, write: if isOwner(userId);
      }

      allow read: if isAuthenticated() && (isOwner(userId) || isNotBanned());
      allow create: if isAuthenticated() && isOwner(userId);
      allow update: if isAuthenticated() && (isAdmin() || (isOwner(userId) && !changed().hasAny(['role', 'status'])));
      allow delete: if isAdmin() || isOwner(userId);

      // Quan hệ bạn bè
      match /friends/{friendId} {
        allow read: if isAuthenticated() && (isOwner(userId) || isOwner(friendId));
        allow write: if isAuthenticated() && (isOwner(userId) || isOwner(friendId));
      }

      // Danh sách chặn
      match /blockedUsers/{blockedUid} {
        allow read: if isAuthenticated() && (isOwner(userId) || isOwner(blockedUid));
        allow write: if isOwner(userId);
      }
    }

    // Lời mời kết bạn
    match /friendRequests/{requestId} {
      allow read: if isAuthenticated() && (resource.data.senderId == request.auth.uid || resource.data.receiverId == request.auth.uid);
      allow create: if isAuthenticated() && request.resource.data.senderId == request.auth.uid;
      allow update, delete: if isAuthenticated() && (resource.data.senderId == request.auth.uid || resource.data.receiverId == request.auth.uid);
    }

    // Bài viết
    match /posts/{postId} {
      allow read: if isNotBanned() && !isBlockedWith(resource.data.authorId) && (
        resource.data.visibility == 'public' ||
        resource.data.authorId == request.auth.uid ||
        (resource.data.visibility == 'friends' && isFriend(resource.data.authorId)) ||
        isAdmin()
      );

      allow create: if isNotBanned() && request.resource.data.authorId == request.auth.uid;
      allow update: if isNotBanned() && (
        resource.data.authorId == request.auth.uid ||
        changed().hasOnly(['commentCount', 'reactions'])
      );
      allow delete: if isAdmin() || (resource.data.authorId == request.auth.uid);

      // Cảm xúc bài viết (Zalo-style)
      match /reactions/{reactorId} {
        allow read: if isNotBanned() && (
          isOwner(get(/databases/$(database)/documents/posts/$(postId)).data.authorId) ||
          reactorId == request.auth.uid ||
          isFriend(get(/databases/$(database)/documents/posts/$(postId)).data.authorId)
        );
        allow write: if isNotBanned() && reactorId == request.auth.uid;
      }
    }

    // Bình luận
    match /comments/{commentId} {
      allow read: if isNotBanned();
      allow create: if isNotBanned() && request.resource.data.authorId == request.auth.uid;
      allow update: if isNotBanned() && (
        resource.data.authorId == request.auth.uid ||
        changed().hasOnly(['replyCount', 'reactions'])
      );
      allow delete: if isAdmin() || resource.data.authorId == request.auth.uid || 
        get(/databases/$(database)/documents/posts/$(resource.data.postId)).data.authorId == request.auth.uid;

      // Cảm xúc bình luận (Zalo-style)
      match /reactions/{reactorId} {
        allow read: if isNotBanned() && (
          isOwner(get(/databases/$(database)/documents/comments/$(commentId)).data.authorId) ||
          reactorId == request.auth.uid ||
          isFriend(get(/databases/$(database)/documents/comments/$(commentId)).data.authorId)
        );
        allow write: if isNotBanned() && reactorId == request.auth.uid;
      }
    }

    // Thông báo
    match /notifications/{notificationId} {
      allow read: if isOwner(resource.data.receiverId);
      allow update: if isOwner(resource.data.receiverId) && changed().hasOnly(['isRead']);
      allow delete: if isOwner(resource.data.receiverId) || isAdmin();
    }

    // Báo cáo vi phạm
    match /reports/{reportId} {
      allow create: if isAuthenticated();
      allow read, update, delete: if isAdmin() || resource.data.reporterId == request.auth.uid;
    }
  }
}

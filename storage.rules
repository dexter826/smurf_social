rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    
    // Ảnh đại diện
    match /avatars/{userId}/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null 
        && request.auth.uid == userId
        && request.resource.size < 5 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
    }
    
    // Ảnh bìa
    match /covers/{userId}/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null 
        && request.auth.uid == userId
        && request.resource.size < 10 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
    }
    
    // Ảnh bài viết - Kiểm soát hiển thị tại Firestore
    match /posts/{userId}/images/{imageId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null 
        && request.auth.uid == userId
        && request.resource.size < 5 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
    }
    
    // Video bài viết - Kiểm soát hiển thị tại Firestore
    match /posts/{userId}/videos/{videoId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null 
        && request.auth.uid == userId
        && request.resource.size < 50 * 1024 * 1024
        && request.resource.contentType.matches('video/.*');
    }
    
    // File trò chuyện (ảnh, video, tài liệu)
    match /chats/{conversationId}/{allPaths=**} {
      allow read: if request.auth != null && 
        request.auth.uid in get(/databases/$(database)/documents/conversations/$(conversationId)).data.participantIds;
      allow write: if request.auth != null
        && request.auth.uid in get(/databases/$(database)/documents/conversations/$(conversationId)).data.participantIds
        && request.resource.size < 10 * 1024 * 1024;
    }
    
    // Ảnh bình luận
    match /comments/{userId}/images/{imageId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null 
        && request.auth.uid == userId
        && request.resource.size < 5 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
    }
    
    // Video bình luận
    match /comments/{userId}/videos/{videoId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null 
        && request.auth.uid == userId
        && request.resource.size < 10 * 1024 * 1024
        && request.resource.contentType.matches('video/.*');
    }
    
    // Stickers
    match /stickers/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if false;
    }
  }
}

rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    
    // Avatar images
    match /avatars/{userId}/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null 
        && request.auth.uid == userId
        && request.resource.size < 5 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
    }
    
    // Cover images
    match /covers/{userId}/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null 
        && request.auth.uid == userId
        && request.resource.size < 10 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
    }
    
    // Post images
    match /posts/{userId}/images/{imageId} {
      allow read: if request.auth != null && (
        request.auth.uid == userId || 
        request.auth.uid in get(/databases/$(database)/documents/users/$(userId)).data.friendIds
      );
      allow write: if request.auth != null 
        && request.auth.uid == userId
        && request.resource.size < 5 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
    }
    
    // Post videos
    match /posts/{userId}/videos/{videoId} {
      allow read: if request.auth != null && (
        request.auth.uid == userId || 
        request.auth.uid in get(/databases/$(database)/documents/users/$(userId)).data.friendIds
      );
      allow write: if request.auth != null 
        && request.auth.uid == userId
        && request.resource.size < 50 * 1024 * 1024
        && request.resource.contentType.matches('video/.*');
    }
    
    // Chat files (images, videos, documents)
    match /chats/{conversationId}/{allPaths=**} {
      allow read: if request.auth != null && 
        request.auth.uid in get(/databases/$(database)/documents/conversations/$(conversationId)).data.participantIds;
      allow write: if request.auth != null
        && request.auth.uid in get(/databases/$(database)/documents/conversations/$(conversationId)).data.participantIds
        && request.resource.size < 10 * 1024 * 1024;
    }
    
    // Comment images
    match /comments/{userId}/images/{imageId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null 
        && request.auth.uid == userId
        && request.resource.size < 5 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
    }
    
    // Comment videos
    match /comments/{userId}/videos/{videoId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null 
        && request.auth.uid == userId
        && request.resource.size < 10 * 1024 * 1024
        && request.resource.contentType.matches('video/.*');
    }
    
    // Stickers
    match /stickers/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if false;
    }
  }
}

rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    
    // ══════════════════════════════════════════
    // AVATARS - 5MB, chỉ ảnh
    // ══════════════════════════════════════════
    match /avatars/{userId}/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null 
        && request.auth.uid == userId
        && request.resource.size < 5 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
    }
    
    // ══════════════════════════════════════════
    // COVERS - 10MB, chỉ ảnh
    // ══════════════════════════════════════════
    match /covers/{userId}/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null 
        && request.auth.uid == userId
        && request.resource.size < 10 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
    }
    
    // ══════════════════════════════════════════
    // POSTS MEDIA - privacy kiểm soát tại Firestore
    // ══════════════════════════════════════════
    match /posts/{userId}/images/{imageId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null 
        && request.auth.uid == userId
        && request.resource.size < 5 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
    }
    
    match /posts/{userId}/videos/{videoId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null 
        && request.auth.uid == userId
        && request.resource.size < 50 * 1024 * 1024
        && request.resource.contentType.matches('video/.*');
    }
    
    // ══════════════════════════════════════════
    // CHATS - 10MB, participant check tại service layer
    // ══════════════════════════════════════════
    match /chats/{conversationId}/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
        && request.resource.size < 10 * 1024 * 1024;
    }
    
    // ══════════════════════════════════════════
    // COMMENTS MEDIA - privacy kiểm soát tại Firestore
    // ══════════════════════════════════════════
    match /comments/{userId}/images/{imageId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null 
        && request.auth.uid == userId
        && request.resource.size < 5 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
    }
    
    // ══════════════════════════════════════════
    // STICKERS - read-only, admin upload thủ công
    // ══════════════════════════════════════════
    match /stickers/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if false;
    }
  }
}

{
  "rules": {
    "presence": {
      "$uid": {
        ".read": "auth != null",
        ".write": "auth != null && auth.uid === $uid"
      }
    },
    "conversations": {
      "$convId": {
        ".read": "auth != null && data.child('members').child(auth.uid).exists()",
        ".write": "auth != null && (data.child('creatorId').val() === auth.uid || data.child('members').child(auth.uid).val() === 'admin')"
      }
    },
    "messages": {
      "$convId": {
        ".read": "auth != null && root.child('conversations').child($convId).child('members').child(auth.uid).exists()",
        "$msgId": {
          ".write": "auth != null && (newData.child('senderId').val() === auth.uid || root.child('conversations').child($convId).child('members').child(auth.uid).exists())"
        }
      }
    },
    "user_chats": {
      "$uid": {
        ".read": "auth != null && auth.uid === $uid",
        ".write": "auth != null && auth.uid === $uid"
      }
    },
    "call_signaling": {
      "$uid": {
        ".read": "auth != null && auth.uid === $uid",
        ".write": "auth != null"
      }
    }
  }
}
